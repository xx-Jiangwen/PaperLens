.container { padding: 12px; }
.categories { white-space: nowrap; margin-bottom: 16px; }
.cat-tag { display: inline-block; padding: 6px 14px; background: #161b22; color: #8b949e; border-radius: 20px; margin-right: 8px; font-size: 12px; }
.cat-tag.active { background: #1f4168; color: #58a6ff; }
.paper-card { background: #161b22; border-radius: 12px; padding: 16px; margin-bottom: 12px; }
.title { color: #e6edf3; font-size: 14px; line-height: 1.5; margin: 8px 0; }
.authors { color: #8b949e; font-size: 12px; margin-bottom: 8px; }
.tag { background: #1f4168; color: #58a6ff; padding: 2px 8px; border-radius: 4px; font-size: 11px; margin-right: 4px; }
.summary-status { font-size: 11px; color: #8b949e; }
.summary-status.done { color: #3fb950; }
