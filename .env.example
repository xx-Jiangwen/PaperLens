# ── 数据库 ──────────────────────────────────────────
DATABASE_URL=sqlite:///./paperpulse.db
# 生产环境改为 PostgreSQL：
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/paperpulse

# ── 安全 ────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-secret-key-32-chars
# API Key 加密用的 Master Key（32字节 hex）
ENCRYPT_MASTER_KEY=change-this-to-a-hex-32-bytes-key

# ── 微信小程序 ────────────────────────────────────────
WX_APP_ID=your_wx_app_id
WX_APP_SECRET=your_wx_app_secret

# ── 官方额度 LLM（用于批量生成摘要）────────────────────
OFFICIAL_LLM_BASE_URL=https://api.openai.com/v1
OFFICIAL_LLM_API_KEY=sk-your-official-api-key
OFFICIAL_LLM_MODEL=gpt-4o-mini

# ── 定时任务 ──────────────────────────────────────────
# 每日抓取的 arXiv 分类（逗号分隔）
DAILY_CATEGORIES=cs.AI,cs.CL,cs.CV,cs.LG,stat.ML
# 每个分类每日最多抓取数量
DAILY_MAX_PER_CATEGORY=50

# ── 服务配置 ──────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false
